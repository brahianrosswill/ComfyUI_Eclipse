{
  "_comment": "Docker Configuration for SML - Supports vLLM, SGLang, Ollama, and llama.cpp backends",
  "backend": "vllm",
  "_comment_backend": "Options: 'vllm' (default), 'sglang' (alternative to vLLM), 'ollama' (for GGUF/Mistral3), 'llamacpp' (for GGUF)",
  "gpu_memory_utilization": 0.6,
  "dtype": "auto",
  "trust_remote_code": true,
  "_comment_global": "gpu_memory_utilization: VRAM fraction (0.0-1.0). dtype/trust_remote_code: model loading options. Docker containers auto-start when needed. Stop after generation is controlled by the node widget.",
  "vllm": {
    "docker_image": "vllm/vllm-openai:latest",
    "url": "http://localhost:8000/v1",
    "port": 8000,
    "timeout": 2,
    "startup_timeout": 600,
    "request_timeout": 300,
    "tensor_parallel_size": 1,
    "_comment_tensor_parallel": "Set to > 1 for multi-GPU. Auto-enabled if model too large for single GPU."
  },
  "sglang": {
    "docker_image": "lmsysorg/sglang:latest",
    "url": "http://localhost:30000/v1",
    "port": 30000,
    "timeout": 5,
    "startup_timeout": 300,
    "request_timeout": 600,
    "container_name_prefix": "sml_sglang",
    "tp_size": 1,
    "dp_size": 1,
    "_comment": "SGLang from LMSYS - Alternative to vLLM with RadixAttention for better throughput",
    "_comment_tp_dp": "tp_size: tensor parallelism (multi-GPU split). dp_size: data parallelism (multi-GPU copies)"
  },
  "ollama": {
    "docker_image": "ollama/ollama",
    "url": "http://localhost:11434/v1",
    "port": 11434,
    "auto_pull": true,
    "startup_timeout": 300,
    "request_timeout": 300,
    "pull_timeout": 1800,
    "gpu_layers": -1,
    "_comment": "Ollama auto-downloads models from registry. gpu_layers: -1 = all layers on GPU."
  },
  "llamacpp": {
    "docker_image": "ghcr.io/ggml-org/llama.cpp:server-cuda",
    "url": "http://localhost:8080/v1",
    "port": 8080,
    "startup_timeout": 300,
    "request_timeout": 180,
    "n_gpu_layers": -1,
    "_comment": "llama.cpp server for GGUF models. n_gpu_layers: -1 = all layers on GPU."
  },
  "paths": {
    "docker_mount": "/models"
  },
  "model_containers": {},
  "llamacpp_containers": {},
  "sglang_model_containers": {}
}