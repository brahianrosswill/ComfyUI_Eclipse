{
  "_comment": "Add your custom models here, organized by backend. Examples below show the required fields per backend.",

  "transformers": {
    "_example_Phi-4-multimodal-instruct": {
      "repo_id": "microsoft/Phi-4-multimodal-instruct",
      "family": "VLM",
      "has_vision": true
    }
  },

  "gguf": {
    "_example_Gemma-3-4B-Instruct": {
      "repo_id": "bartowski/gemma-3-4b-it-GGUF",
      "family": "LLM_TEXT",
      "has_vision": false,
      "quantizations": ["Q4_K_M", "Q6_K", "Q8_0"],
      "file_pattern": "gemma-3-4b-it-{quant}.gguf"
    }
  },

  "ollama": {
    "_example_gemma3:4b": {
      "repo_id": "gemma3:4b",
      "family": "LLM_TEXT",
      "has_vision": false
    }
  },

  "vllm": {
    "_example_Phi-4-multimodal-instruct": {
      "repo_id": "microsoft/Phi-4-multimodal-instruct",
      "family": "VLM",
      "has_vision": true,
      "tensor_parallel": 1
    }
  },

  "sglang": {
    "_example_Qwen2.5-VL-32B-Instruct": {
      "repo_id": "Qwen/Qwen2.5-VL-32B-Instruct",
      "family": "Qwen",
      "has_vision": true,
      "tensor_parallel": 2,
      "data_parallel": 1
    }
  },

  "wd14": {
    "_example_WD14-custom-finetune": {
      "repo_id": "myuser/wd-custom-tagger-v3"
    }
  }
}
