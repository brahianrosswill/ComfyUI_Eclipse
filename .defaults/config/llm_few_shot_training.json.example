{
    "_description": "SFW few-shot training examples for LLM and vision tasks. Safe-for-work variant with no explicit content. Each mode has its instruction template and optional examples. System prompts come from smartlm_prompt_defaults.json. Vision tasks use text-only examples to guide output style (no example images needed).",
    "simple_description": {
        "display_name": "Simple Description",
        "instruction_template": "",
        "examples": [
            {
                "role": "user",
                "content": "Describe this image concisely."
            },
            {
                "role": "assistant",
                "content": "Shot from a slightly elevated angle, a young woman with wavy auburn hair sits at a sunlit café table, her green eyes sparkling as she lifts a ceramic latte cup to her lips with both hands."
            },
            {
                "role": "user",
                "content": "Describe this image concisely."
            },
            {
                "role": "assistant",
                "content": "Captured from a straight-on eye-level perspective, a bearded man in a leather jacket leans against a weathered brick wall, arms crossed, with the warm glow of a street lamp behind him."
            },
            {
                "role": "user",
                "content": "Describe this image concisely."
            },
            {
                "role": "assistant",
                "content": "Viewed from a low angle looking up, a woman in a flowing red dress stands atop a grassy hill, her hair swept by the wind against a dramatic cloudy sky."
            },
            {
                "role": "user",
                "content": "Describe this image concisely."
            },
            {
                "role": "assistant",
                "content": "Framed in a medium shot from a three-quarter angle, an elderly couple walks hand-in-hand along a cobblestone path, autumn leaves scattered around their feet, smiling warmly at each other."
            }
        ]
    },
    "detailed_description": {
        "display_name": "Detailed Description",
        "instruction_template": "",
        "examples": [
            {
                "role": "user",
                "content": "Describe this image in detail."
            },
            {
                "role": "assistant",
                "content": "Seen from a close-up three-quarter angle, a woman with long dark hair cascading over her denim jacket sits at an outdoor wooden table, resting her chin on one hand. She gazes thoughtfully toward the viewer with parted lips and half-closed eyes. The camera is positioned slightly below her eye line, lending an intimate perspective. A half-finished cappuccino and an open sketchbook sit before her, and warm golden light from the setting sun casts soft shadows across her face."
            },
            {
                "role": "user",
                "content": "Describe this image in detail."
            },
            {
                "role": "assistant",
                "content": "Photographed from a full-body frontal angle at eye level, a tall man with short cropped hair stands in a modern kitchen, wearing a fitted navy henley with the sleeves pushed to his elbows. His arms rest casually at his sides as he leans against the marble countertop. Flour dusts his forearms and apron, and a rolling pin lies on the counter beside fresh dough. Warm pendant lighting overhead casts an inviting glow across the space."
            },
            {
                "role": "user",
                "content": "Describe this image in detail."
            },
            {
                "role": "assistant",
                "content": "Captured from a low side angle at floor level, a woman in black athletic wear performs a yoga warrior pose on a bamboo mat. Her spine is long and straight, front knee bent at ninety degrees, arms extended wide with fingers spread. Her focused gaze follows her leading hand. The muscles in her legs and arms are visibly engaged. A bright airy studio with wooden floors and large windows provides clean natural lighting, and a row of potted plants lines the window ledge."
            },
            {
                "role": "user",
                "content": "Describe this image in detail."
            },
            {
                "role": "assistant",
                "content": "Framed from a high overhead perspective looking straight down, a couple lies on a checkered picnic blanket in a sun-dappled park. She rests on her back reading a paperback, one hand behind her head. He lies on his stomach beside her, propped on his elbows, sketching in a notebook. A wicker basket of fruit and a bottle of sparkling water sit between them. Dappled golden light filters through the canopy of trees above, casting shifting patterns across the scene."
            }
        ]
